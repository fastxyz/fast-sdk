{
  "name": "@fastxyz/sdk",
  "version": "1.1.0-beta.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/fastxyz/fast-sdk",
    "directory": "packages/fast-sdk"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./core": {
      "import": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/core/index.ts --format esm --dts",
    "dev": "tsup src/index.ts src/core/index.ts --format esm --watch --dts"
  },
  "dependencies": {
    "@fastxyz/schema": "workspace:*",
    "@mysten/bcs": "^2.0.3",
    "@noble/ed25519": "^3.0.1",
    "@noble/hashes": "^2.0.1",
    "bech32": "^2.0.0",
    "effect": "^3.21.0",
    "json-with-bigint": "^3.5.8"
  },
  "devDependencies": {
    "@types/node": "^25.5.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
