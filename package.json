{
  "name": "@fastxyz/monorepo",
  "private": true,
  "description": "Official JS SDK and CLI Monorepo for Fast",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "cli": "tsx app/cli/src/main.ts",
    "format": "prettier --write \"**/*.{ts,js,json,md}\"",
    "clean": "turbo clean && rm -rf node_modules",
    "pub:changeset": "pnpm changeset",
    "pub:testnet": "pnpm changeset pre enter testnet",
    "pub:exit-pre": "pnpm changeset pre exit",
    "pub:version": "pnpm changeset version",
    "pub:release": "pnpm build && pnpm changeset publish --provenance --access public",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "turbo": "^2.8.20",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  },
  "packageManager": "pnpm@10.1.0",
  "pnpm": {
    "ignoredBuiltDependencies": [
      "esbuild",
      "msgpackr-extract",
      "@parcel/watcher",
      "better-sqlite3",
      "esbuild",
      "msgpackr-extract",
      "@parcel/watcher"
    ],
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
