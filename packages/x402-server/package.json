{
  "name": "@fastxyz/x402-server",
  "version": "0.1.0",
  "description": "Server SDK for the x402 HTTP Payment Protocol — Express middleware for paywall and payment verification",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastxyz/x402-types": "workspace:*"
  },
  "peerDependencies": {
    "express": ">=4"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "vitest": "^1.6.0"
  }
}
