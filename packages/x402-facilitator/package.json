{
  "name": "@fastxyz/x402-facilitator",
  "version": "1.0.2",
  "description": "Facilitator for the x402 HTTP Payment Protocol — verify and settle payments on-chain",
  "repository": {
    "type": "git",
    "url": "https://github.com/fastxyz/fast-sdk",
    "directory": "packages/x402-facilitator"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastxyz/schema": "workspace:*",
    "@fastxyz/sdk": "workspace:*",
    "@fastxyz/x402-types": "workspace:*",
