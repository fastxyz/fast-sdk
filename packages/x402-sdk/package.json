{
  "name": "@fastxyz/x402-sdk",
  "version": "0.1.0",
  "description": "SDK for the x402 HTTP Payment Protocol — monetize APIs with crypto payments",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./client": {
      "import": "./dist/client/index.js",
      "types": "./dist/client/index.d.ts"
    },
    "./server": {
      "import": "./dist/server/index.js",
      "types": "./dist/server/index.d.ts"
    },
    "./facilitator": {
      "import": "./dist/facilitator/index.js",
      "types": "./dist/facilitator/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "keywords": [
    "x402",
    "http",
    "payment",
    "402",
    "fast",
    "evm",
    "eip-3009",
    "crypto"
  ],
  "author": "Fast.xyz",
  "license": "MIT",
  "dependencies": {
    "@fastxyz/allset-sdk": "workspace:*",
    "@fastxyz/fast-schema": "workspace:*",
    "@fastxyz/fast-sdk": "workspace:*",
    "viem": "^2.46.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "typescript": "^6.0.2",
    "vitest": "^1.6.0"
  },
  "peerDependencies": {
    "express": "^4.18.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
